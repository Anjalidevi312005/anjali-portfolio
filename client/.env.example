# Copy this file to ".env" (for local) or set in your host (Vercel/Netlify) for production.

# Backend API base URL.
# Local dev: leave EMPTY — Vite proxies /api to the local backend automatically.
# Production: set to your deployed backend + /api, e.g.
#   VITE_API_URL=https://anjali-portfolio-api.onrender.com/api
VITE_API_URL=
