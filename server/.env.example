# Copy this file to ".env" and fill in your values.

# Server port (5000 is taken by macOS AirPlay Receiver, so we use 5050)
PORT=5050

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/anjali_portfolio
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/anjali_portfolio
MONGO_URI=mongodb://127.0.0.1:27017/anjali_portfolio

# Allowed frontend origin(s) for CORS. Vite dev default is 5173.
# In production set this to your deployed frontend URL, e.g.
#   CLIENT_ORIGIN=https://anjali-portfolio.vercel.app
# Multiple origins allowed (comma-separated):
#   CLIENT_ORIGIN=https://anjali-portfolio.vercel.app,http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173

# Email notifications (optional) — get an alert when someone submits the contact form.
# Uses Resend (https://resend.com) — works on hosts that block SMTP (like Render free).
# RESEND_API_KEY = your API key from resend.com (required to enable)
# NOTIFY_TO      = where alerts go (defaults to your email in email.js)
# RESEND_FROM    = optional; defaults to "Portfolio <onboarding@resend.dev>"
RESEND_API_KEY=
NOTIFY_TO=
RESEND_FROM=

# Telegram alerts (optional) — instant phone notification on new message.
# TELEGRAM_BOT_TOKEN = from @BotFather on Telegram
# TELEGRAM_CHAT_ID   = your numeric chat id (from @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
