# Copy this file to ".env" and fill in your values.

# Server port (5000 is taken by macOS AirPlay Receiver, so we use 5050)
PORT=5050

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/anjali_portfolio
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/anjali_portfolio
MONGO_URI=mongodb://127.0.0.1:27017/anjali_portfolio

# Allowed frontend origin(s) for CORS. Vite dev default is 5173.
# In production set this to your deployed frontend URL, e.g.
#   CLIENT_ORIGIN=https://anjali-portfolio.vercel.app
# Multiple origins allowed (comma-separated):
#   CLIENT_ORIGIN=https://anjali-portfolio.vercel.app,http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173
